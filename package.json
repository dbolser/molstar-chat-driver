{
  "name": "molstar-chat-driver",
  "version": "0.2.0",
  "description": "A chat interface for Mol*: type natural-language prompts and drive the Mol* viewer via MolViewSpec (MVS) scenes.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Dan Bolser",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "node esbuild.mjs build && tsc -p tsconfig.json --emitDeclarationOnly",
    "demo": "node esbuild.mjs demo",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "molstar": ">=4 <6"
  },
  "peerDependenciesMeta": {
    "molstar": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.23.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "molstar",
    "molviewspec",
    "mvs",
    "molecular-visualization",
    "chat",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbolser/molstar-chat-driver.git"
  }
}
