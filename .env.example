# molstar-chat-driver — demo backend config.
# Copy to `.env` and fill in just the provider you want to use:
#
#     cp .env.example .env
#
# `.env` is gitignored — never commit real keys. `npm run demo` watches this file,
# so edits take effect without restarting. With no key, the demo runs in keyword
# mode (a few hard-coded scenes). Already-exported shell vars take precedence.

# Which model the backend uses. Format: provider:model-id (see the slots below).
# Default: anthropic:claude-haiku-4-5 — small, cheap, and plenty good for MVS.
# MODEL=anthropic:claude-haiku-4-5

# --- Anthropic ------------------------------------------------------------------
# spec: anthropic:<id>   e.g.  anthropic:claude-haiku-4-5
ANTHROPIC_API_KEY=

# --- OpenAI ---------------------------------------------------------------------
# spec: openai:<id>      e.g.  openai:gpt-4o
OPENAI_API_KEY=
# Optional: point at any OpenAI-compatible host (Together, Groq, local Ollama/vLLM):
# OPENAI_BASE_URL=

# --- Google Gemini (OpenAI-compatibility layer) ---------------------------------
# spec: gemini:<id>      e.g.  gemini:gemini-2.5-flash
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- OpenRouter (one key, hundreds of models) -----------------------------------
# spec: openrouter:<vendor>/<id>
#   e.g.  openrouter:meta-llama/llama-3.3-70b-instruct
OPENROUTER_API_KEY=
