# Copy this file to `.env` to enable the real LLM backend for the demo.
# Without a key, the demo runs in keyword mode (a few hard-coded scenes) — no key needed.

# Your Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model to use (optional; default: claude-opus-4-8)
# MODEL=claude-opus-4-8
